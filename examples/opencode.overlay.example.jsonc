{
  // INTERNAL OVERLAY EXAMPLE — keep a filled-in version of this in a PRIVATE team repo, never in
  // the public kit. It layers your real proxy IDs + team conventions over the generic kit.
  //
  // Usage: merge into the project's opencode.jsonc, or keep as the team's ~/.config/opencode config.
  "$schema": "https://opencode.ai/config.json",

  // Real proxy wiring (values live in your private repo / env, not here).
  "provider": {
    "lmproxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM AI Factory",
      "options": {
        "baseURL": "https://YOUR-REAL-PROXY/v1",
        "apiKey": "{env:LM_PROXY_API_KEY}"
      },
      "models": {
        // The EXACT IDs from `opencode models` (adjust if your proxy's catalog differs).
        "claude-4-5-sonnet-latest": { "name": "Sonnet 4.5" },
        "gpt-5.1": { "name": "GPT-5.1" },
        "nemotron-3-ultra-550b-a55b": { "name": "Nemotron Ultra (reasoning)" },
        "mistral-large-3-675b-instruct-2512": { "name": "Mistral Large 3" },
        "nemotron-3-nano-30b-a3b": { "name": "Nemotron Nano (cheap, 1M ctx)" }
      }
    }
  },
  "model": "claude-4-5-sonnet-latest",     // bare ID — no provider prefix

  // Load team conventions on top of the kit's AGENTS.md (your private coding standards, the shared
  // libs' ns2.0 constraints, the API contract location, naming, etc.).
  "instructions": [
    "AGENTS.md",
    "memory/MEMORY.md",
    "team/CONVENTIONS.md"          // <- your private team standards
  ],

  // Internal MCP servers (only what's approved): internal docs, issue tracker, the live API
  // contract spec, etc. Add as approvals come through.
  "mcp": {
    // Windows: wrap npx in `cmd /c` or you get "MCP error -32000 connection closed". POSIX: drop it.
    "patterns": { "type": "local", "command": ["cmd","/c","npx","-y","@modelcontextprotocol/server-filesystem","./patterns"], "enabled": true }
    // "internal-docs": { "type": "remote", "url": "https://INTERNAL", "enabled": true }
  }

  // Tip: pin which model each agent uses here too, if you don't want to edit the kit's agent files
  // directly — keeps the public kit pristine and your real choices in the private overlay.
}
