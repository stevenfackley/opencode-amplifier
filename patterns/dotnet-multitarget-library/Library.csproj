<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- ns2.0 = max reach (the compile floor); net10.0 = modern fast paths. -->
    <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>           <!-- annotations on BOTH targets -->
    <ImplicitUsings>disable</ImplicitUsings>
  </PropertyGroup>

  <!-- Polyfills + backports ONLY for the ns2.0 floor (net10 has these in-box). -->
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <!-- PolySharp is source-only: enables record/init/required with no runtime dependency. -->
    <PackageReference Include="PolySharp" Version="1.*" PrivateAssets="all" />
    <PackageReference Include="System.Text.Json" Version="8.*" />
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" Version="8.*" />
  </ItemGroup>

</Project>
